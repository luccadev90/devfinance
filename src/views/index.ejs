<%- include('partials/header', { title: title }) %>

<!-- ===== ALERTA DO MÊS ===== -->
<div class="alert alert-info">
    <strong>
        <% 
            const meses = ['Janeiro','Fevereiro','Março','Abril','Maio','Junho',
                          'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro'];
            const nomeMes = meses[(selectedMonth || 1) - 1];
        %>
        📅 <%= isCurrentMonth ? 'Mês Atual' : 'Histórico' %>: 
        <strong><%= nomeMes %> de <%= selectedYear || 2024 %></strong>
        | Total: <strong><%= finances.length %></strong> transações
    </strong>
</div>

<!-- ===== CARDS ===== -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h6>Receitas</h6>
                <h3>R$ <%= (balances && balances.totalIncome ? balances.totalIncome : 0).toFixed(2) %></h3>
                <small>Pago: R$ <%= (balances && balances.paidIncome ? balances.paidIncome : 0).toFixed(2) %></small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <h6>Despesas</h6>
                <h3>R$ <%= (balances && balances.totalExpense ? balances.totalExpense : 0).toFixed(2) %></h3>
                <small>Pago: R$ <%= (balances && balances.paidExpense ? balances.paidExpense : 0).toFixed(2) %></small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h6>Saldo</h6>
                <h3>R$ <%= (balances && balances.balance ? balances.balance : 0).toFixed(2) %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark text-white">
            <div class="card-body">
                <h6>Total</h6>
                <h3><%= finances.length %></h3>
            </div>
        </div>
    </div>
</div>

<!-- ===== FILTROS ===== -->
<div class="card mb-4">
    <div class="card-body">
        <form method="GET" action="/" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Mês</label>
                <select name="month" class="form-select" onchange="this.form.submit()">
                    <option value="current" <%= monthFilter === 'current' ? 'selected' : '' %>>Mês Atual</option>
                    <% if (availableMonths && availableMonths.length > 0) { %>
                        <% availableMonths.forEach(function(m) { %>
                            <option value="<%= m.month %>" 
                                    <%= (monthFilter == m.month && yearFilter == m.year) ? 'selected' : '' %>>
                                <%= String(m.month).padStart(2, '0') %>/<%= m.year %> (<%= m.count %>)
                            </option>
                        <% }); %>
                    <% } %>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select" onchange="this.form.submit()">
                    <option value="all" <%= statusFilter === 'all' ? 'selected' : '' %>>Todos</option>
                    <option value="pending" <%= statusFilter === 'pending' ? 'selected' : '' %>>Pendente</option>
                    <option value="paid" <%= statusFilter === 'paid' ? 'selected' : '' %>>Pago</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Tipo</label>
                <select name="type" class="form-select" onchange="this.form.submit()">
                    <option value="all" <%= typeFilter === 'all' ? 'selected' : '' %>>Todos</option>
                    <option value="income" <%= typeFilter === 'income' ? 'selected' : '' %>>Receita</option>
                    <option value="expense" <%= typeFilter === 'expense' ? 'selected' : '' %>>Despesa</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <input type="hidden" name="year" value="<%= yearFilter %>">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<!-- ===== TABELA ===== -->
<div class="card">
    <div class="card-header d-flex justify-content-between">
        <h5>Transações</h5>
        <div>
            <a href="/add" class="btn btn-success btn-sm">+ Nova</a>
            <a href="/export/pdf" target="_blank" class="btn btn-danger btn-sm">PDF</a>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Descrição</th>
                    <th>Tipo</th>
                    <th>Valor</th>
                    <th>Data</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% if (!finances || finances.length === 0) { %>
                    <tr>
                        <td colspan="7" class="text-center py-4">
                            <h5>Nenhuma transação encontrada</h5>
                            <a href="/add" class="btn btn-primary btn-sm">Adicionar</a>
                        </td>
                    </tr>
                <% } else { %>
                    <% finances.forEach(function(f, i) { %>
                        <tr>
                            <td><%= i + 1 %></td>
                            <td><%= f.description %></td>
                            <td>
                                <span class="badge <%= f.type === 'income' ? 'bg-success' : 'bg-danger' %>">
                                    <%= f.type === 'income' ? 'Receita' : 'Despesa' %>
                                </span>
                            </td>
                            <td>R$ <%= f.amount.toFixed(2) %></td>
                            <td><%= new Date(f.date).toLocaleDateString('pt-BR') %></td>
                            <td>
                                <span class="badge <%= f.status === 'paid' ? 'bg-success' : 'bg-warning' %>">
                                    <%= f.status === 'paid' ? 'Pago' : 'Pendente' %>
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-info" onclick="toggleStatus('<%= f._id %>')">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                                <a href="/edit/<%= f._id %>" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete('<%= f._id %>')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('partials/footer') %>